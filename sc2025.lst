  80                    	
  81                    save:	
  82 00-100 104 266 010 load:	JMP EXEC		; By default, save and load isn't implemented.
  83                    
  84                    INPORT:  EQU 5
  85                    OUTPORT: EQU 6  ;016
  86                    	
  87                    ;;; 2025-03-18 Erturk
  88                    ;;; RetroShield method of serial i/o
  89                    ;;; CPRINT: Output character to OUTPORT - teensy will Serial.write() it.
  90                    ;;; CINP: Read byte from INPORT
  91                    ;;; - bit 7 = Serial.available() return value. 1=char available, 0=no char available.
  92                    ;;; - bit 6..0 = character read by Serial.read() & 0x7F
  93                    
  94                    ;;; SCELBAL code is assembled with soft-uart routines.
  95                    ;;; However Teensy code can override these routines w/
  96                    ;;; direct drive CINP2 and CPRINT2 routines.
  97                    ;;;   see scelbal.h for #define SCELBAL_USES_SOFT_UART 0
  98                    
  99                    ;CINP2:	INP INPORT          ; teensy will set bit7 = Serial.available()
 100                    ;	NDA                        ; bit7 set?
 101                    ;	JFS CINP                   ; no, keep waiting
 102                    ;	OUT OUTPORT                ; echo
 103                    ;	RET                        ; ascii char will be returned w/ bit7 set.
 104                    	
 105                    ;CPRINT2: OUT OUTPORT        ; tell teensy to Serial.write() it.
 106                    ;	RET
